{
  // ---------------------------------------------------------------------------------
  // | GLOBAL                                                                        |
  // ---------------------------------------------------------------------------------
  "telemetry.telemetryLevel": "off",
  "window.zoomPerWindow": true,
  "window.zoomLevel": 0,
  "files.autoSave": "onFocusChange",
  "files.autoSaveWorkspaceFilesOnly": true,
  "workbench.startupEditor": "newUntitledFile",
  "extensions.ignoreRecommendations": true,
  "editor.accessibilitySupport": "off",
  // ---------------------------------------------------------------------------------
  // | TERMINAL                                                                      |
  // ---------------------------------------------------------------------------------
  "terminal.integrated.shellIntegration.enabled": false,
  "terminal.integrated.tabs.enabled": true,
  "terminal.integrated.tabs.location": "left",
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.cursorStyle": "block",
  "terminal.integrated.profiles.linux": {
    "bash": { "path": "bash", "icon": "terminal-bash" },
    "python3 (global)": { "path": "python3" },
    "python3.7 (global)": { "path": "python3.7" },
    "python3.8 (global)": { "path": "python3.8" },
    "python3.9 (global)": { "path": "python3.9" },
    "python3.10 (global)": { "path": "python3.10" }
  },
  "terminal.integrated.defaultProfile.linux": "bash",
  "terminal.integrated.automationProfile.linux": { "path": "bash" },
  "terminal.integrated.env.linux": {},
  "terminal.integrated.profiles.windows": {
    "bash (git)": {
      "source": "Git Bash",
      "args": ["--login"],
      "icon": "terminal-bash"
    },
    "PowerShell": { "source": "PowerShell", "icon": "terminal-powershell" },
    "cmd": {
      "path": [
        "${env:windir}\\Sysnative\\cmd.exe",
        "${env:windir}\\System32\\cmd.exe"
      ],
      "args": [],
      "icon": "terminal-cmd"
    },
    "python (global)": { "path": "python" },
    "python3.7 (global)": { "path": "python3.7" },
    "python3.8 (global)": { "path": "python3.8" },
    "python3.9 (global)": { "path": "python3.9" },
    "python3.10 (global)": { "path": "python3.10" }
  },
  "terminal.integrated.defaultProfile.windows": "bash (git)",
  "terminal.integrated.automationProfile.windows": { "path": "bash" },
  "terminal.external.windowsExec": "C:\\Program Files\\Git\\bin\\bash.exe",
  "terminal.integrated.env.windows": {},
  // ---------------------------------------------------------------------------------
  // | EDITOR                                                                        |
  // ---------------------------------------------------------------------------------
  "workbench.editor.empty.hint": "hidden",
  "workbench.editor.limit.enabled": true,
  "workbench.editor.limit.perEditorGroup": true,
  "editor.largeFileOptimizations": false,
  "editor.unicodeHighlight.ambiguousCharacters": true,
  "editor.unicodeHighlight.invisibleCharacters": true,
  "editor.unicodeHighlight.nonBasicASCII": true,
  "editor.unicodeHighlight.includeComments": false,
  "editor.unicodeHighlight.allowedCharacters": {
    "ä": true,
    "Ä": true,
    "ö": true,
    "Ö": true,
    "ü": true,
    "Ü": true,
    "ß": true
  },
  "editor.mouseWheelZoom": false,
  "editor.minimap.enabled": false,
  "editor.minimap.scale": 1,
  "editor.minimap.showSlider": "always",
  "editor.minimap.renderCharacters": false,
  "editor.codeLens": false,
  "editor.folding": false,
  "editor.wordWrapColumn": 100,
  "editor.suggestSelection": "first",
  "editor.multiCursorModifier": "ctrlCmd",
  "editor.rulers": [100, 120],
  "files.associations": {
    ".babelrc": "json",
    ".csslintrc": "json",
    "cargo.lock": "toml",
    "*.ddl": "sql",
    ".env": "ini",
    ".eslintignore": "ignore",
    ".htmlhintrc": "json",
    ".htmllintrc": "jsonc",
    ".linguirc": "json",
    "*.log?": "log",
    "*.log.?": "log",
    ".prettierignore": "ignore",
    ".prettierrc": "json",
    "Pipfile": "toml",
    "Pipfile.lock": "json",
    "poetry.lock": "toml",
    "*.rst_t": "jinja",
    ".sqlfluff": "ini",
    ".vuerc": "json",
    ".yamllint": "yaml"
  },
  "files.exclude": {
    "**/__pycache__": true
  },
  "diffEditor.ignoreTrimWhitespace": false,
  "diffEditor.maxComputationTime": 0,
  // ---------------------------------------------------------------------------------
  // | COLORS / THEMEING                                                             |
  // ---------------------------------------------------------------------------------
  // ==============================
  // BRACKETS
  // ==============================
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": "active",
  // ==============================
  // FONTS == != ===
  // ==============================
  "editor.fontFamily": "'ComicCodeLigatures Nerd Font', 'ComicCodeLigatures NF', 'Comic Code Ligatures', 'Hack Nerd Font Mono', 'FiraCode Nerd Font Mono', 'Hack NF', 'FiraCode NF', Consolas, monospace",
  "editor.fontLigatures": true,
  // "editor.fontSize": 13,
  "terminal.integrated.fontFamily": "'ComicCodeLigatures Nerd Font', 'ComicCodeLigatures NF', 'Comic Code Ligatures', 'Hack Nerd Font Mono', 'FiraCode Nerd Font Mono', 'Hack NF', 'FiraCode NF', Consolas, monospace",
  // "terminal.integrated.fontSize": 13,
  // ==============================
  // (ICON) THEME
  // ==============================
  "workbench.colorTheme": "Krys Colors",
  "workbench.iconTheme": "file-icons",
  "editor.semanticTokenColorCustomizations": {
    "[Krys Colors]": {
      // Apply to this theme only
      "enabled": true
      // "enabled"   : false
    }
  },
  "editor.guides.indentation": false,
  "workbench.colorCustomizations": {},
  // ---------------------------------------------------------------------------------
  // | GIT / GITHUB                                                                  |
  // ---------------------------------------------------------------------------------
  "git.autofetch": true,
  "git.terminalAuthentication": false,
  "git.terminalGitEditor": true,
  "git.inputValidationSubjectLength": 80,
  "git.inputValidationLength": 100,
  "git.inputValidation": true,
  "git.openRepositoryInParentFolders": "never",
  "[git-commit]": {
    "editor.rulers": [50, 72, 80, 100],
    "editor.wordWrap": "off",
    "workbench.editor.restoreViewState": false
  },
  "github.gitProtocol": "ssh",
  "github.copilot.nextEditSuggestions.enabled": true,
  "chat.tools.urls.autoApprove": {
    "https://learn.microsoft.com/en-us/azure/devops/pipelines/tasks/reference/advanced-security-dependency-scanning-v1": {
      "approveRequest": false,
      "approveResponse": true
    }
  },
  // ---------------------------------------------------------------------------------
  // | EXTENSIONS (coloring/highlighting)                                            |
  // ---------------------------------------------------------------------------------
  // ==============================
  // indent-rainbow
  // ==============================
  "indentRainbow.colors": [
    "rgba(255,255,64,0.15)", // ffff4026
    "rgba(127,255,127,0.15)", // 7fff7f26
    "rgba(255,127,255,0.15)", // ff7fff26
    "rgba(79,236,236,0.15)" // 4fecec26
  ],
  "indentRainbow.ignoreErrorLanguages": ["markdown", "restructuredtext"],
  // ==============================
  // Error Lens
  // ==============================
  "errorLens.messageTemplate": "$severity [1/$count] $message [$source] <$code>",
  "errorLens.statusBarMessageTemplate": "$severity $message [$source]",
  "errorLens.delay": 1,
  "errorLens.gutterIconsEnabled": true,
  "errorLens.gutterIconSet": "defaultOutline",
  // ---------------------------------------------------------------------------------
  // | EXTENSIONS (tooling)                                                          |
  // ---------------------------------------------------------------------------------
  // ==============================
  // Code Runner
  // ==============================
  "code-runner.enableAppInsights": false, // telemetry
  // ==============================
  // VS IntelliCode
  // ==============================
  "vsintellicode.modify.editor.suggestSelection": "automaticallyOverrodeDefaultValue",
  "vsintellicode.features.python.deepLearning": "enabled",
  // ==============================
  // Todo Tree
  // ==============================
  "todo-tree.filtering.includeHiddenFiles": true,
  // "todo-tree.regex.regex": "(//|#|;|<!--|/\\*{1,2}|\\.\\.|--|^|^[ \\t]*(-|\\d+.))\\s*($TAGS)",
  "todo-tree.regex.regex": "((//|#|;|\\.\\.|--|^|^[ \t]*(-|\\d+.))\\s*($TAGS))|(<!--\\s*($TAGS).*(\\s|.)*?-->)|(/\\*{1,2}\\s*($TAGS)(\\s|.)*?\\*/)",
  "[javascript][javascriptreact][typescript][typescriptreact]": {
    "todo-tree.regex.regex": "(//\\s*($TAGS))|(/\\*{1,2}\\s*($TAGS)(\\s|.)*?\\*/)"
  },
  "todo-tree.regex.enableMultiLine": true,
  "todo-tree.general.debug": true,
  "todo-tree.general.statusBar": "tags",
  "todo-tree.general.tags": [
    "NOTE:",
    "CHANGE ME",
    "TODO:",
    "FIXME:",
    "BUG:",
    "HACK:"
  ],
  "todo-tree.highlights.enabled": true,
  "todo-tree.highlights.defaultHighlight": {
    "opacity": 90,
    "type": "tag"
  },
  "todo-tree.highlights.customHighlight": {
    "NOTE:": {
      "foreground": "#fff",
      "background": "#008000",
      "icon": "note",
      "iconColour": "#008000",
      "gutterIcon": false,
      "type": "text",
      "rulerColour": "#0000",
      "hideFromStatusBar": true,
      "hideFromTree": true
    },
    "CHANGE ME": {
      "foreground": "#000",
      "background": "#00ffff",
      "icon": "arrow-switch",
      "iconColour": "#00ffff",
      "gutterIcon": false,
      "type": "text",
      "rulerColour": "#0000",
      "hideFromStatusBar": true
      // "hideFromTree": true
    },
    "TODO:": {
      "foreground": "#000",
      "background": "#ff00d4",
      "icon": "checklist",
      "iconColour": "#ff00d4",
      "gutterIcon": false,
      "type": "text",
      "rulerColour": "#ff00d4"
    },
    "FIXME:": {
      "foreground": "#fff",
      "background": "#ff4500",
      "icon": "flame",
      "iconColour": "#ff4500",
      "gutterIcon": true,
      "type": "whole-line",
      "rulerColour": "#ff0000"
    },
    "BUG:": {
      "foreground": "#fff",
      "background": "#ff0000",
      "icon": "bug",
      "iconColour": "#ff0000",
      "gutterIcon": true,
      "type": "text",
      "rulerColour": "#ff0000"
    },
    "HACK:": {
      "foreground": "#000",
      "background": "#ffa500",
      "icon": "beaker",
      "iconColour": "#ffa500",
      "gutterIcon": true,
      "type": "text",
      "rulerColour": "#ffa500"
    }
  },
  "todo-tree.tree.showCountsInTree": true,
  "todo-tree.filtering.excludeGlobs": [
    // DIRECTORIES
    "**/node_modules/**",
    "**/bower_components/**",
    "**/dist/**",
    "**/build/**",
    "**/.vscode/**",
    "**/_output/**",
    "**/*.min.*",
    "**/*.map",
    "**/.next/**",
    "**/.tox/**",
    "**/.nox/**",
    "**/*venv*/**",
    // FILES
    "**/.gitignore",
    "**/.gitattributes"
  ],
  // ==============================
  // Spell Right
  // ==============================
  "spellright.language": ["en"],
  "spellright.documentTypes": ["markdown", "latex", "plaintext"],
  "spellright.ignoreFiles": ["**/.gitignore", "**/.spellignore"],
  // ==============================
  // Jest
  // ==============================
  "jest.showTerminalOnLaunch": false,
  "jest.autoRun": "off",
  "testing.followRunningTest": false,
  "testing.openTesting": "neverOpen",
  // ---------------------------------------------------------------------------------
  // | EXTENSIONS (languages)                                                        |
  // ---------------------------------------------------------------------------------
  // ==============================
  // PYTHON
  // ==============================
  "python.terminal.activateEnvInCurrentTerminal": false,
  "python.venvPath": "${workspaceFolder}/.venv/bin/activate",
  "python.languageServer": "Pylance",
  "python.analysis.completeFunctionParens": true,
  "python.analysis.typeCheckingMode": "off",
  "python.analysis.autoImportCompletions": true,
  "black-formatter.args": [
    "--safe",
    "--config=${workspaceFolder}/pyproject.toml"
  ],
  "ruff.configuration": {
    "lint": {
      "unfixable": ["ERA001", "F401", "F841"],
    },
  },
  "mypy-type-checker.args": ["--config-file=${workspaceFolder}/pyproject.toml"],
  "mypy-type-checker.importStrategy": "fromEnvironment",
  "mypy-type-checker.path": ["${workspaceFolder}/.tox/mypy/bin/mypy"],
  "mypy-type-checker.showNotifications": "onWarning",
  "[python]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "charliermarsh.ruff", // ms-python.black-formatter
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit",
      "source.fixAll": "explicit"
    }
  },
  // ==============================
  // Python Docstring Generator (python)
  // ==============================
  "autoDocstring.docstringFormat": "sphinx",
  "autoDocstring.includeExtendedSummary": true,
  "autoDocstring.customTemplatePath": "~/.config/VSCodium/User/sphinx_docstring_template_custom.mustache",
  // ==============================
  // Jupyter
  // ==============================
  "notebook.cellToolbarLocation": {
    "default": "right",
    "jupyter-notebook": "left"
  },
  // ==============================
  // CSS
  // ==============================
  "[css]": {
    "editor.tabSize": 2
  },
  "tailwindCSS.experimental.classRegex": [
    ["cva\\(((\\S|\\s)*?)\\);", "[\"'`]([^\"'`]*).*?[\"'`]"],
    ["cx\\(((\\S|\\s)*?)\\);", "(?:'|\"|`)([^']*)(?:'|\"|`)"]
  ],
  "tailwindCSS.classAttributes": [
    "class",
    "className",
    "classNames",
    "ngClass",
    "class:list"
  ],
  // ==============================
  // JavaScript / TypeScript
  // ==============================
  "[javascript][typescript][javascriptreact][typescriptreact]": {
    "editor.tabSize": 2,
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "dbaeumer.vscode-eslint",
    "editor.codeActionsOnSave": {
      "source.organizeImports": "never",
      // prettier removes unreachable code probably via ts
      "source.fixAll": "never",
      "source.fixAll.eslint": "explicit"
    }
  },
  "js/ts.updateImportsOnFileMove.enabled": "prompt",
  "js/ts.updateImportsOnPaste.enabled": false,
  "js/ts.format.semicolons": "insert",
  "js/ts.preferences.useAliasesForRenames": false,
  "js/ts.preferences.quoteStyle": "double",
  "js/ts.enablePromptUseWorkspaceTsdk": true,
  "js/ts.inlayHints.functionLikeReturnTypes.enabled": true,
  "prettier.prettierPath": "./node_modules/prettier",
  "eslint.run": "onSave",
  "eslint.format.enable": true,
  "eslint.debug": true,
  "eslint.options": {
    "overrideConfigFile": "eslint.config.ts",
    "flags": ["unstable_ts_config"],
    "overrideConfig": {
      "linterOptions": { "reportUnusedDisableDirectives": false }
    }
  },
  "eslint.useFlatConfig": true,
  "console-ninja.outputMode": "In View",
  "console-ninja.featureSet": "Community",  // ==============================  // TypeScript  // ==============================
  // ==============================
  // reStructuredText
  // ==============================
  "redhat.telemetry.enabled": false,
  "esbonio.sphinx.buildDir": "${workspaceFolder}/docs/build/html",
  "esbonio.sphinx.confDir": "${workspaceFolder}/docs/source",
  "esbonio.server.enabled": true,
  "restructuredtext.linter.rst-lint.executablePath": "${workspaceFolder}/.venv/bin/rstcheck",
  "restructuredtext.linter.rst-lint.extraArgs": [
    "--config ${workspaceFolder}/.rstcheck.cfg"
  ],
  "restructuredtext.linter.rstcheck.executablePath": "${workspaceFolder}/.venv/bin/rstcheck",
  "restructuredtext.linter.rstcheck.extraArgs": [
    "--config ${workspaceFolder}/.rstcheck.cfg"
  ],
  "restructuredtext.linter.run": "onSave",
  // ==============================
  // Markdown
  // ==============================
  "markdown.extension.preview.autoShowPreviewToSide": false,
  "markdown.extension.tableFormatter.normalizeIndentation": true,
  "markdown.extension.toc.slugifyMode": "github",
  // "markdown.extension.toc.slugifyMode": "azureDevops",
  "markdown.extension.toc.levels": "1..3",
  "[markdown]": {
    "editor.formatOnSave": false,
    "editor.defaultFormatter": "yzhang.markdown-all-in-one",
    // "editor.codeActionsOnSave": {
    //   "source.organizeImports": "explicit",
    //   "source.fixAll": "explicit"
    // }
    "editor.wordWrap": "off"
  },
  // ==============================
  // json
  // ==============================
  "[json][jsonc]": {
    "editor.tabSize": 2,
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit",
      "source.fixAll": "explicit"
    }
  },
  // ==============================
  // toml
  // ==============================
  "[toml]": {
    "editor.tabSize": 2,
    "editor.insertSpaces": true,
    "editor.language.brackets": [
      ["[", "]"],
      ["{", "}"]
    ],
    "editor.language.colorizedBracketPairs": [
      ["[", "]"],
      ["{", "}"]
    ]
  },
  "evenBetterToml.semanticTokens": true,
  // ==============================
  // dockercompose
  // ==============================
  "[dockercompose]": {
    "editor.insertSpaces": true,
    "editor.tabSize": 2,
    "editor.autoIndent": "advanced",
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  // ==============================
  // Github Actions Workflow files
  // ==============================
  "[github-actions-workflow]": {
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  // ==============================
  // Svelte
  // ==============================
  "svelte.enable-ts-plugin": true,
  // ==============================
  // SQL
  // ==============================
  "sqltools.disableChordKeybindings": true,
  "sqltools.useNodeRuntime": true,
  "sqltools.detectNodeRuntime": false,
  "sqltools.disableNodeDetectNotifications": true,
  "sqltools.completionLanguages": ["sql"],
  "inlineSQL.dbDriver": "mysql",
  "sqlfluff.linter.run": "onSave",
  "sqlfluff.format.enabled": true,
  "sqlfluff.experimental.format.executeInTerminal": true,
  "[sql]": {
    "editor.acceptSuggestionOnCommitCharacter": false,
    "editor.formatOnSave": false,
    "editor.defaultFormatter": "dorzey.vscode-sqlfluff"
  },
  // ==============================
  // NEW
  // ==============================
  "testing.automaticallyOpenTestResults": "neverOpen",
}
